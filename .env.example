# Backend
PORT=3333
NODE_ENV=development
API_KEY=
# API docs are enabled by default outside production. Set true explicitly if production needs Swagger UI.
ENABLE_API_DOCS=
# Comma-separated browser origins allowed to call the API in production.
# Example: CORS_ORIGINS=https://agentops.example.com,https://agentops.vercel.app
CORS_ORIGINS=
LOG_LEVEL=info
DATA_STORE=file
DATA_FILE_PATH=../data/agentops-store.json
POSTGRES_URL=postgres://agentops:agentops@localhost:5432/agentops
POSTGRES_PASSWORD=replace-with-a-long-random-password
# Optional RBAC API keys: role:key,role:key
# Example: API_KEYS=operator:dev-operator-key,reviewer:dev-reviewer-key,admin:dev-admin-key
API_KEYS=
# Public demo access key for portfolio/recruiter testing. Use a long random value.
# In Vercel, set the same value in DEMO_API_KEY and VITE_DEMO_API_KEY.
DEMO_API_KEY=
DEMO_RATE_LIMIT_MAX=30
DEMO_RATE_LIMIT_WINDOW_MS=600000
LLM_PROVIDER=mock
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=local-master-key
LITELLM_MODEL=azure-gpt-4o-mini
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_GENERATIVE_AI_MODEL=gemini-2.5-flash
MASTRA_MODEL=google/gemini-2.5-flash
# Optional Stitch design automation. OAuth is preferred for generation; API key can list tools but may not create screens.
STITCH_API_KEY=
STITCH_ACCESS_TOKEN=
GOOGLE_CLOUD_PROJECT=
EMBEDDINGS_PROVIDER=local
VECTOR_STORE=memory
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=agentops_documents
OUTBOX_PUBLISHER=local
AZURE_SERVICE_BUS_CONNECTION_STRING=
AZURE_SERVICE_BUS_TOPIC=agentops-events
UPLOAD_MAX_BYTES=1000000
DOCUMENT_STORAGE=local
DOCUMENT_STORAGE_DIR=../data/uploads
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=agentops-documents
OTEL_SERVICE_NAME=agentops-backend
SEED_DEMO_DATA=true

# Frontend
VITE_API_BASE_URL=http://localhost:3333
VITE_DEMO_API_KEY=
