{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts src/server.ts --format esm --dts --clean --out-dir dist",
    "start": "node dist/index.js",
    "mastra:dev": "mastra dev --dir mastra",
    "mastra:studio": "mastra studio --server-port 4111 --port 3001",
    "mastra:build": "mastra build --dir mastra",
    "db:migrate": "node scripts/migrate-postgres.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.80",
    "@azure/service-bus": "^7.9.5",
    "@azure/storage-blob": "^12.31.0",
    "@fastify/cors": "^11.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@mastra/core": "^1.37.1",
    "@napi-rs/canvas": "^0.1.80",
    "@opentelemetry/api": "^1.9.1",
    "ai": "^6.0.192",
    "dotenv": "^17.2.3",
    "fastify": "^5.8.5",
    "html-to-text": "^10.0.0",
    "mammoth": "^1.12.0",
    "nanoid": "^5.1.6",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "pino": "^10.1.0",
    "read-excel-file": "^9.0.10",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.20.0",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
