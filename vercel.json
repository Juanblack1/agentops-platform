{
  "installCommand": "npm ci",
  "buildCommand": "npm run build -w backend && npm run build -w frontend",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "env": {
    "DATA_STORE": "memory",
    "DOCUMENT_STORAGE": "local",
    "DOCUMENT_STORAGE_DIR": "/tmp/agentops-uploads",
    "LLM_PROVIDER": "mock",
    "VECTOR_STORE": "memory",
    "OUTBOX_PUBLISHER": "local",
    "SEED_DEMO_DATA": "true",
    "LOG_LEVEL": "warn"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/health",
      "destination": "/api/index"
    },
    {
      "source": "/readiness",
      "destination": "/api/index"
    },
    {
      "source": "/docs/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/docs",
      "destination": "/api/index"
    }
  ]
}
