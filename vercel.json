{
  "installCommand": "npm ci",
  "buildCommand": "npm run build -w backend && npm run build -w frontend",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "functions": {
    "api/index.ts": {
      "includeFiles": "node_modules/pdfjs-dist/legacy/build/pdf.worker.mjs",
      "maxDuration": 30
    }
  },
  "env": {
    "DATA_STORE": "postgres",
    "DOCUMENT_STORAGE": "azure-blob",
    "DOCUMENT_STORAGE_DIR": "/tmp/agentops-uploads",
    "VECTOR_STORE": "pgvector",
    "OUTBOX_PUBLISHER": "servicebus",
    "LOG_LEVEL": "warn"
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/health",
      "destination": "/api/index"
    },
    {
      "source": "/readiness",
      "destination": "/api/index"
    },
    {
      "source": "/docs/(.*)",
      "destination": "/api/index"
    },
    {
      "source": "/docs",
      "destination": "/api/index"
    }
  ]
}
